{
  "name": "@wilson/root",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "author": "Christoph Werner <christoph@codepunkt.de>",
  "workspaces": [
    "docs",
    "packages/*"
  ],
  "scripts": {
    "docs:build": "npm run build --workspace @wilson/docs",
    "docs:start": "npm run start --workspace @wilson/docs",
    "docs:serve": "npm run serve --workspace @wilson/docs",
    "wilson:build": "npm run build --workspace wilson",
    "wilson:start": "npm run start --workspace wilson",
    "start": "run-p wilson:start docs:start",
    "build": "run-s wilson:build docs:build docs:serve",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "engines": {
    "node": ">= 16.15.0",
    "npm": ">= 8.5.5"
  },
  "prettier": {
    "endOfLine": "lf",
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "arrowParens": "always",
    "printWidth": 80,
    "overrides": [
      {
        "files": "*.md",
        "options": {
          "printWidth": 60
        }
      }
    ]
  },
  "lint-staged": {
    "{docs,packages}/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.26.0",
    "@typescript-eslint/parser": "^5.23.0",
    "eslint": "^8.15.0",
    "eslint-config-preact": "^1.1.4",
    "husky": "^8.0.1",
    "lint-staged": "^12.4.1",
    "npm-run-all": "^4.1.5",
    "patch-package": "^6.4.7",
    "prettier": "^2.4.0",
    "typescript": "^4.2.3"
  }
}
